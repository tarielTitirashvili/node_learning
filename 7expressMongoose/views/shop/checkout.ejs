<%- include('../_common/includes/head') %>
    <link rel="stylesheet" href="/css/product.css">
    <script src="https://js.stripe.com/dahlia/stripe.js"></script>
    </head>

    <body>
        <%- include('../_common/includes/header') %>

            <main>
                <% if(products.length> 0){ %>
                    <% products.map(({productId: product, quantity})=>{ %>
                        <div class="grid">
                            <article class="card product-item">
                                <header class="card__header">
                                    <h1 class="product__title">
                                        <%= product.title %>
                                    </h1>
                                </header>
                                <div class="card__image">
                                    <img src="<%= product.imageUrl %>" alt="A Book">
                                </div>
                                <div class="card__conte nt">
                                    <h2 class="product__price">
                                        <%= product.price %>
                                    </h2>
                                    <p class="product__description">
                                        <%= product.description %>
                                    </p>
                                    <strong class="centred">quantity: <%= quantity %></strong>
                                </div>
                            </article>
                        </div>
                        <% }) %>
                            <p class="centred">
                                <b>Total: </b>
                                <%= total %>
                            </p>
                            <div class="centred">
                                <form action="/create-order" method="POST">
                                    <input type="hidden" name="_csrf" value="<%= csurfToken %>" />
                                    <button type="submit" class="btn">Order Now!</button>
                                </form>
                                <form id="payment-form">
                                    <div id="payment-element">
                                        <!-- Stripe Elements will mount here -->
                                    </div>
                                    <input type="hidden" name="_csrf" value="<%= csurfToken %>" />
                                </form>
                                <a href="<%=session.url%>">
                                    <button class="btn" id="submit">Pay now</button>
                                </a>
                                <!-- <script>
                                    const stripe = Stripe('pk_test_51TkVCtHe6eZD1CGCIpFLYR1XCe5dDHVMmaotEnHogCBQ5WyueHrsNNw1u1OxuY1kMBDs67cr8YYkX2ZeJbDFMrs200wzdGG37W')
                                    const orderBtn = document.getElementById('pay-now-btn')
                                    orderBtn.addEventListener('click', function () {
                                        window.location.href = '<%=session.url%>'
                                    })
                                </script> -->
                            </div>
                            <% } else {%>
                                <h1>Product Not Found</h1>
                                <% } %>


            </main>
    </body>

    </html>