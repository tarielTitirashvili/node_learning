<%- include('../_common/includes/head') %>
  <link rel="stylesheet" href="/css/product.css">
  </head>

  <body>
    <%- include('../_common/includes/header') %>

      <main>
        <h1>Admin Products</h1>
        <p>List of all the products Editable...</p>
        <% if(products.length> 0){ %>
          <% products.map((product)=>{ %>
            <div class="grid">
              <article class="card product-item">
                <header class="card__header">
                  <h1 class="product__title">
                    <%= product.title %>
                  </h1>
                </header>
                <div class="card__image">
                  <img src="<%= product.imageUrl %>" alt="A Book">
                </div>
                <div class="card__content">
                  <h2 class="product__price">
                    <%= product.price %>
                  </h2>
                  <p class="product__description">
                    <%= product.description %>
                  </p>
                </div>
                <div class="card__actions">
                  <a class="btn" href="/admin/edit-product/<%= product._id %>">Edit</a>
                  <input type="text" name="id" hidden value="<%= product._id %>" />
                  <input type="hidden" name="_csrf" value="<%= csurfToken %>" />

                  <button type="submit" onclick="deleteProduct(this)" class="btn">Delete</button>
                </div>
              </article>
            </div>
            <% }) %>
              <% } else {%>
                <h1>Product Not Found</h1>
                <% } %>
      </main>
  </body>
  <script src="/js/admin.js"></script>

  </html>