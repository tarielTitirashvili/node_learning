<%- include('../_common/includes/head') %>
    <link rel="stylesheet" href="/css/forms.css">
    <link rel="stylesheet" href="/css/product.css">
    </head>

    <body>
        <%- include('../_common/includes/header') %>

            <main>
                <form class="product-form" action="/admin/add-product" method="POST" enctype="multipart/form-data">
                    <div class="form-control">
                        <label for="title">Title</label>
                        <input class="<%= validationErrors.find(e => e.path === 'title') ? 'invalid' : '' %>"
                            value="<%= product ? product?.title : '' %>" type="text" name="title" id="title">
                    </div>
                    <!-- <div class="form-control">
                        <label for="imageURL">image URL</label>
                        <input class="<%= validationErrors.find(e => e.path === 'imageURL') ? 'invalid' : '' %>"
                            value="<%= product ? product?.imageURL || '' : '' %>" type="text" name="imageURL"
                            id="imageURL">
                    </div> -->
                    <div class="form-control">
                        <label for="image">Image</label>
                        <input type="file" name="image" id="image">
                    </div>
                    <div class="form-control">
                        <label for="price">price</label>
                        <input class="<%= validationErrors.find(e => e.path === 'price') ? 'invalid' : '' %>"
                            value="<%= product ? product?.price : '' %>" type="numeric" name="price" id="price">
                    </div>
                    <div class="form-control">
                        <label for="description">description</label>
                        <input class="<%= validationErrors.find(e => e.path === 'description') ? 'invalid' : '' %>"
                            value="<%= product ? product?.description : '' %>" type="text" name="description"
                            id="description">
                    </div>
                    <input type="hidden" name="_csrf" value="<%= csurfToken %>" />
                    <button class="btn" type="submit">Add Product</button>
                </form>
            </main>
    </body>

    </html>