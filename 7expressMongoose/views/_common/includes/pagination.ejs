<section class="pages">
  <% if(currentPage > 2){ %>
    <a href="?page=1">1</a>
    ...
  <% } %>
  <% if(currentPage !== 1){ %>
    <a href="?page=<%= prevPage %>"><%= prevPage %></a>
  <% } %>
  <a href="?page=<%=currentPage %>" class="active"><%=currentPage %></a>
  <% if(hasNextPage){ %>
    <a href="?page=<%= nextPage %>"><%= nextPage %></a>
  <% } %>
  <% if(nextPage < lastPage){ %>
    ...
    <a href="?page=<%= lastPage %>"><%= lastPage %></a>
  <% } %>
</section>